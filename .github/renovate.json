{
  
  "extends": [
    "config:recommended",
    "group:definitelyTyped",
    "group:fortawesome",
    "group:linters",
    "group:reactMonorepo"
  ],
  "labels": [
    "library"
  ],
  "packageRules": [
    {
      "packageNames": [
        "Microsoft.EntityFrameworkCore"
      ],
      "packagePatterns": [
        "^Microsoft\\.EntityFrameworkCore\\..+$"
      ],
      "groupName": "Microsoft.EntityFrameworkCore monorepo"
    },
    {
      "groupName": "NSwag monorepo",
      "sourceUrlPrefixes": [
        "https://github.com/RicoSuter/NSwag"
      ]
    }
  ],
  "postUpdateOptions": [
    "yarnDedupeHighest"
  ],
  "rebaseWhen": "behind-base-branch",,
  "automerge": true,
  "automergeType": "branch",
  "schedule": ["after 1am and before 2am"]
}
