{
  "private": true,
  "name": "clientapp",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preact-cli": "cross-env NODE_OPTIONS=--openssl-legacy-provider npx -y node@20 ./node_modules/preact-cli/src/index.js",
    "build": "yarn preact-cli build --no-esm",
    "serve": "sirv build --port 8080 --cors --single",
    "dev": "yarn preact-cli watch --no-esm && echo Starting the development server",
    "lint": "eslint src/**/*.{js,jsx,ts,tsx} --fix",
    "test": "jest src/tests",
    "type-check": "tsc --noEmit"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{css,md,scss}": "prettier --write",
    "*.{js,jsx,ts,tsx}": "eslint --fix"
  },
  "dependencies": {
    "@microsoft/applicationinsights-react-js": "19.4.1",
    "@microsoft/applicationinsights-web": "3.4.2",
    "@microsoft/signalr-protocol-msgpack": "10.0.0",
    "@react-oauth/google": "^0.13.0",
    "@reduxjs/toolkit": "2.12.0",
    "@s-libs/micro-dash": "21.1.0",
    "@types/preval.macro": "^3.0.2",
    "@types/react": "file:./src/types/fake-empty",
    "bulma": "1.0.4",
    "bulma-toast": "2.4.4",
    "cross-env": "10.1.0",
    "javascript-time-ago": "^2.5.9",
    "preact": "10.29.3",
    "preact-router": "4.1.2",
    "pretty-bytes": "7.1.0",
    "preval.macro": "^5.0.0",
    "promise-file-reader": "1.0.3",
    "react-bulma-components": "4.1.0",
    "react-icons": "5.7.0",
    "react-redux": "9.3.0",
    "react-timer-hook": "4.0.6",
    "redux-persist": "6.0.0",
    "regenerator-runtime": "0.14.1",
    "save-file": "2.3.1",
    "ts-date": "3.1.0",
    "tslib": "^2.8.1",
    "uuid-int": "3.1.0"
  },
  "devDependencies": {
    "@teamsupercell/typings-for-css-modules-loader": "2.5.2",
    "@types/enzyme": "3.10.19",
    "@types/jest": "30.0.0",
    "@types/webpack-env": "1.18.8",
    "@typescript-eslint/eslint-plugin": "8.62.1",
    "@typescript-eslint/parser": "8.62.1",
    "css-loader": "7.1.4",
    "enzyme": "3.11.0",
    "enzyme-adapter-preact-pure": "4.1.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-functional": "^10.0.0",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "jest-preset-preact": "4.1.1",
    "lint-staged": "17.0.8",
    "preact-cli": "3.5.1",
    "preact-cli-plugin-env-vars": "1.2.1",
    "preact-render-to-string": "6.7.0",
    "prettier": "3.9.4",
    "sirv-cli": "3.0.1",
    "typescript": "6.0.3"
  }
